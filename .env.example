# ============================================================
# AutoEOD — Environment Variables
# Copy this file to .env and fill in all values.
# NEVER commit the .env file to version control.
# ============================================================

# --- Database ---
# PostgreSQL connection string (matches docker-compose defaults)
DATABASE_URL=postgresql://autoeod:autoeod@localhost:5432/autoeod

# --- Redis ---
# Redis connection URL (matches docker-compose defaults)
REDIS_URL=redis://localhost:6379

# --- JWT ---
# Generate strong random secrets: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=your-access-secret-here-min-32-chars
JWT_REFRESH_SECRET=your-refresh-secret-here-min-32-chars

# --- Encryption ---
# AES-256-GCM key for encrypting GitHub tokens at rest
# Must be exactly 64 hex characters (32 bytes)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your-64-char-hex-encryption-key-here

# --- GitHub OAuth ---
# Create a GitHub OAuth App at: https://github.com/settings/developers
# Set callback URL to: http://localhost:3001/api/integrations/github/callback
GITHUB_CLIENT_ID=your-github-oauth-app-client-id
GITHUB_CLIENT_SECRET=your-github-oauth-app-client-secret
GITHUB_CALLBACK_URL=http://localhost:3001/api/integrations/github/callback

# --- OpenAI ---
# Your OpenAI API key (get from: https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-your-openai-api-key-here

# --- Resend (Email) ---
# Get your API key from: https://resend.com/api-keys
RESEND_API_KEY=re_your-resend-api-key-here
# The "from" address for sent emails (must be a verified domain in Resend)
EMAIL_FROM=AutoEOD <reports@yourdomain.com>

# --- Frontend ---
# URL of the frontend app (for CORS and OAuth redirect)
FRONTEND_URL=http://localhost:5173

# --- API Server ---
PORT=3001
NODE_ENV=development
