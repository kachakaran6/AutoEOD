{
  "name": "autoeod",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:api": "npm run dev --workspace=apps/api",
    "dev:worker": "npm run dev --workspace=apps/worker",
    "dev:web": "npm run dev --workspace=apps/web",
    "build": "npm run build --workspaces --if-present",
    "postinstall": "npm run db:generate",
    "start": "npm run push --workspace=packages/db && npm run start --workspace=apps/api",
    "start:worker": "npm run push --workspace=packages/db && npm run start --workspace=apps/worker",
    "db:migrate": "npm run migrate --workspace=packages/db",
    "db:migrate:deploy": "npm run migrate:deploy --workspace=packages/db",
    "db:generate": "npm run generate --workspace=packages/db",
    "db:studio": "npm run studio --workspace=packages/db"
  }
}
