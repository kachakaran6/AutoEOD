{
  "manifest_version": 3,
  "name": "AutoEOD \u2014 Activity Radar",
  "version": "1.0.2",
  "description": "Universal browser activity capture for your AutoEOD daily report.",
  "permissions": ["storage", "alarms", "tabs"],
  "host_permissions": [
    "<all_urls>",
    "http://localhost:3001/*",
    "https://autoeod-production.up.railway.app/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": ["content-script.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "AutoEOD"
  }
}
